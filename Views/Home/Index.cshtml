@{
    ViewData["Title"] = "Home Page";
}


<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-10">

            <div class="card shadow-lg border-0">
                <div class="card-body text-center p-5">

                    <h1 class="display-5 fw-bold text-primary">
                        Welcome to Bank Management System
                    </h1>

                    <p class="lead text-muted mt-3">
                        Manage your bank account easily, securely, and efficiently.
                    </p>

                    <hr class="my-4">

                    <div class="row mt-4">
                        <div class="col-md-4">
                            <div class="p-3">
                                <i class="bi bi-cash-coin fs-1 text-success"></i>
                                <h5 class="mt-2">Deposits</h5>
                                <p class="text-muted">
                                    Secure and instant deposits to your account.
                                </p>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="p-3">
                                <i class="bi bi-arrow-left-right fs-1 text-primary"></i>
                                <h5 class="mt-2">Transfers</h5>
                                <p class="text-muted">
                                    Transfer money between accounts safely.
                                </p>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="p-3">
                                <i class="bi bi-journal-text fs-1 text-warning"></i>
                                <h5 class="mt-2">Transactions</h5>
                                <p class="text-muted">
                                    Track all your transactions with full history.
                                </p>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4">
                        <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-lg me-2">
                            Login
                        </a>
                        <a asp-controller="Account" asp-action="Register" class="btn btn-outline-secondary btn-lg">
                            Create Account
                        </a>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>