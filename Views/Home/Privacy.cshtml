@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-9">

            <div class="card shadow-sm">
                <div class="card-body p-4">

                    <h2 class="fw-bold text-primary mb-3">
                        Privacy Policy
                    </h2>

                    <p class="text-muted">
                        Your privacy is important to us. This Bank Management System
                        is designed for educational purposes and follows best practices
                        to protect user data.
                    </p>

                    <h5 class="mt-4">Information Usage</h5>
                    <p class="text-muted">
                        All user information is used only to provide core banking
                        functionalities such as transactions, balance tracking,
                        and account management.
                    </p>

                    <h5 class="mt-3">Data Security</h5>
                    <p class="text-muted">
                        We apply validation, authentication, and authorization
                        techniques to ensure secure access to the system.
                    </p>

                    <h5 class="mt-3">Disclaimer</h5>
                    <p class="text-muted">
                        This project is a demo application and should not be used
                        in production without proper security enhancements.
                    </p>

                </div>
            </div>

        </div>
    </div>
</div>
