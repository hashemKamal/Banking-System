@model IEnumerable<BankProject.Models.Transaction>

<h3>Transaction History</h3>

<table class="table table-hover text-center align-middle">
    <thead>
        <tr>
            <th>Date</th>
            <th>Type</th>
            <th>Amount</th>
            <th>Description</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var t in Model)
        {
            <tr>
                <td>@t.TransactionDate.ToString("dd MMM yyyy - HH:mm")</td>
                <td>
                    <span class="badge @(t.TransactionType == TransactionType.Deposit ? "bg-success" :
                                                                  t.TransactionType == TransactionType.Withdrawal ? "bg-warning" : "bg-primary")">
                        @t.TransactionType
                    </span>
                </td>
                <td class="@(t.TransactionType == TransactionType.Deposit ? "text-success" : "text-danger")">
                    @(t.TransactionType == TransactionType.Deposit ? "+" : "-")$@t.Amount.ToString("N2")
                </td>
                <td>@t.Description</td>
            </tr>
        }
    </tbody>
</table>
